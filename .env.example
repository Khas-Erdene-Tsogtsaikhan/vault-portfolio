NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Primary valuation source for VAULT's collector pricing niche.
PRICECHARTING_API_TOKEN=

# Meilisearch owns the full PriceCharting catalog. Supabase must never store catalog CSVs.
MEILI_HOST=
MEILI_MASTER_KEY=
MEILI_SEARCH_KEY=

# Legendary CSV download URLs used only by scripts/seed-meilisearch.ts or GitHub Actions.
PRICECHARTING_CSV_URL=

# Optional comma-separated Legendary CSV download URLs for multiple catalog files.
PRICECHARTING_CSV_URLS=

# Optional bearer secret for POST /api/market/refresh daily jobs.
MARKET_REFRESH_SECRET=

# Used by scripts/run-daily-refresh.ts in GitHub Actions or local cron.
VAULT_APP_URL=https://vault-portfolio-production.up.railway.app

# Transactional portfolio emails.
RESEND_API_KEY=
RESEND_FROM_EMAIL=VAULT <updates@yourdomain.com>
NEXT_PUBLIC_SITE_URL=https://vault-portfolio-production.up.railway.app
